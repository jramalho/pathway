# Strapi CMS URL — public (bundled into the app via Expo's EXPO_PUBLIC_ prefix).
#
# iOS Simulator / Android Emulator: localhost works (maps to host machine).
# Physical device: localhost does NOT reach your dev machine. Use your machine's
# local network IP (e.g. 192.168.x.x:1337) or a publicly accessible URL.
#
# Do not commit real environment values. Copy this file to .env and adjust.
EXPO_PUBLIC_STRAPI_URL=http://localhost:1337
