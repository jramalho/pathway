# Strapi CMS URL — public (bundled into the app via Expo's EXPO_PUBLIC_ prefix).
# localhost works in iOS Simulator / Android Emulator but NOT on a physical device.
# For a physical device, use your machine's local network IP (e.g. 192.168.x.x:1337)
# or a publicly accessible URL. Do not commit real environment values.
EXPO_PUBLIC_STRAPI_URL=http://localhost:1337
