{
  "name": "pathway",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev:mobile": "pnpm --filter @pathway/mobile start",
    "dev:mobile:android": "pnpm --filter @pathway/mobile android",
    "dev:mobile:ios": "pnpm --filter @pathway/mobile ios",
    "dev:web": "pnpm --filter @pathway/web dev",
    "dev:cms": "pnpm --filter @pathway/cms develop",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @pathway/api test && pnpm --filter @pathway/mobile test"
  }
}
